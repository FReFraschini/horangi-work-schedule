APP_NAME="Horangi Work Schedule"
APP_ENV=production
APP_KEY=                          # generato con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://horangi.duckdns.org

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=horangi
DB_USERNAME=horangi
DB_PASSWORD=           # scegli una password sicura (stessa di DB_PASSWORD nel .env root)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@horangi.duckdns.org"
MAIL_FROM_NAME="${APP_NAME}"
